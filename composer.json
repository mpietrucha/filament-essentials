{
    "name": "mpietrucha/filament-essentials",
    "description": "Filament essentials.",
    "license": "MIT",
    "type": "library",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Michał Pietrucha",
            "email": "michal.pietrucha@off-site.pl"
        }
    ],
    "require": {
        "php": "^8.5",
        "composer-runtime-api": "^2.2",
        "bezhansalleh/filament-plugin-essentials": "^1.2",
        "bezhansalleh/filament-shield": "^4.1",
        "guava/filament-modal-relation-managers": "^3.0",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/database": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/view": "^13.0",
        "league/csv": "^9.28",
        "livewire/blaze": "^1.0",
        "mpietrucha/laravel-essentials": "^1.0",
        "mpietrucha/support": "^1.0",
        "outerweb/filament-translatable-fields": "^4.1",
        "spatie/invade": "^2.1",
        "spatie/laravel-translation-loader": "^2.8"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.1",
        "ergebnis/composer-normalize": "^2.5",
        "filament/filament": "^5.4",
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.29",
        "leek/rector-filament": "dev-main",
        "orchestra/testbench": "^11.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "rector/type-perfect": "^2.1",
        "symfony/var-dumper": "^8.0"
    },
    "provide": {
        "illuminate/contracts": "^12.0",
        "illuminate/support": "^12.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Mpietrucha\\Filament\\Essentials\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mpietrucha\\Filament\\Essentials\\FilamentEssentialsServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@composer normalize"
        ],
        "post-create-project-cmd": [
            "@prettier:config"
        ],
        "lint": "pint --verbose",
        "prettier:config": "curl -sSLO https://raw.githubusercontent.com/mpietrucha/prettier/refs/heads/main/dist/.prettierrc",
        "refactor": "vendor/bin/rector process --ansi",
        "refactor:dry": "@refactor --dry-run",
        "test": [
            "@test:lint",
            "@test:types"
        ],
        "test:lint": "@lint --test",
        "test:types": "phpstan analyse --ansi"
    },
    "$schema": "https://getcomposer.org/schema.json"
}
